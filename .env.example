DATABASE_URL=postgres://usuario:senha@host:5432/banco
# Use a string de conexão do PostgreSQL, não a URL pública do app no Vercel.
JWT_SECRET=troque-por-uma-chave-grande-e-aleatoria
# Padrao do app: 90d para manter o usuario logado no celular.
JWT_EXPIRES_IN=90d
PORT=3000
APP_PUBLIC_URL=https://seu-dominio-ou-url-vercel.app
# Separe multiplas origens por virgula. Mantenha a URL da Vercel e futuros dominios.
APP_ALLOWED_ORIGINS=https://seu-dominio-ou-url-vercel.app
MAIL_FROM=Controle Financeiro <suporte@seudominio.com.br>
RESEND_API_KEY=
EMAIL_LOGO_URL=https://seu-dominio-ou-url-vercel.app/img/logo-email.png
# Fallback opcional via SMTP. Prefira RESEND_API_KEY em produção.
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=financialcontrol@outlook.com.br
SMTP_PASS=
